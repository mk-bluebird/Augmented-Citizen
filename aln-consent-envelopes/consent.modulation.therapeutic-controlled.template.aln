# File: /aln-consent-envelopes/consent.modulation.therapeutic-controlled.template.aln
# Purpose:
# Template for tightly controlled, therapeutic-only modulation of mental
# state under medical/clinical oversight, with neurorights-oriented safeguards
# for mental integrity, continuity, and cognitive liberty.[web:96][web:101][web:116][web:118][web:140][web:142][web:144]

consent_template ModulationTherapeuticControlled_v1 {
    ###########################################################################
    # 1. Template identity and scope
    ###########################################################################

    template_id   = "CONSENT_MODULATION_THERAPEUTIC_CONTROLLED_v1"
    category      = "THERAPEUTIC_MODULATION"
    description   = "Consent for controlled, clinically indicated modulation with clear scope, oversight, and review; no enhancement or commercial goals."

    applicable_to = [
        "DEVICLESS_ORGANIC_INTEGRATIONS",
        "ABSTRACT_COGNITIVE_CHANNELS"
    ]

    baseline_posture = "NO_MODULATION_UNLESS_THIS_OR_HIGHER_TEMPLATE_IS_ACTIVE"

    ###########################################################################
    # 2. Neurorights and host-profile binding
    ###########################################################################

    neurorights_binding {
        rights = [
            "MENTAL_INTEGRITY",
            "PSYCHOLOGICAL_CONTINUITY",
            "COGNITIVE_LIBERTY",
            "MENTAL_PRIVACY"
        ][web:96][web:101][web:116][web:118]

        invariants_refs = [
            "/aln-core-spec/invariants.mental-integrity.aln",
            "/aln-core-spec/invariants.psychological-continuity.aln",
            "/aln-core-spec/invariants.cognitive-liberty.aln"
        ]

        overlay_binding = "/aln-bci-special/bci.special.host-personal-policy.overlay.v2.aln"
    }

    host_healthcare_context_binding {
        host_healthcare_schema = "/aln-core-spec/host.healthcare-context.aln"
        constraints = [
            "THERAPEUTIC_MODULATION_MUST_BE_TIED_TO_DOCUMENTED_CONDITION_OR_SYMPTOM",
            "NO_USE_FOR_GENERAL_PERFORMANCE_ENHANCEMENT_OR_THIRD_PARTY_GOALS"
        ][web:142][web:144]
    }

    ###########################################################################
    # 3. Envelope structure (instantiated per host/therapy plan)
    ###########################################################################

    envelope_schema ConsentEnvelopeTherapeuticModulation {
        fields = [
            "envelope_id",
            "host_did",
            "bostrom_address",
            "clinical_indication",
            "responsible_clinician_id",
            "channels_modulated",
            "modulation_parameters",
            "session_limits",
            "risk_disclosure_summary",
            "benefit_expectation_summary",
            "valid_from",
            "valid_until",
            "review_schedule",
            "revocation_mechanism",
            "host_affirmation_record"
        ]

        constraints = [
            "CLINICAL_INDICATION_MUST_BE_NON_EMPTY_AND_REFER_TO_HOST_HEALTH_RECORD",
            "RESPONSIBLE_CLINICIAN_ID_MUST_BE_VERIFIABLE",
            "CHANNELS_MODULATED_MUST_EXCLUDE_CORE_BELIEF_KERNELS_PER_RED_LINES",
            "MODULATION_PARAMETERS_MUST_INCLUDE_INTENSITY_DURATION_AND_TARGETED_EFFECTS",
            "SESSION_LIMITS_MUST_BE_DEFINED_AND_NOT_UNBOUNDED"
        ]
    }

    ###########################################################################
    # 4. Allowed channels and excluded domains
    ###########################################################################

    allowed_channels {
        # Mapping to deviceless domain model; modulation is still abstract.[web:96][web:101][web:116][web:118]
        references = [
            "/aln-bci-special/bci.special.host-personal-policy.overlay.v2.aln::deviceless_bci.cognitive_channels"
        ]

        # Example therapeutic-friendly mapping
        channel_policies = [
            {
                channel_id = "CC_AFFECTIVE_STATE"
                mode       = "CONTROLLED_MODULATION"
                notes      = "Short-term relief of clinically significant distress; no long-term conditioning patterns."
            },
            {
                channel_id = "CC_PERCEPTUAL_INPUT"
                mode       = "CONTROLLED_MODULATION"
                notes      = "Therapeutic sensory normalization or relief under clinician supervision."
            },
            {
                channel_id = "CC_MEMORY_ADJACENT"
                mode       = "LIMITED_SUPPORT"
                notes      = "Support for intrusive memories or recall; no memory erasure or rewriting."
            },
            {
                channel_id = "CC_META_COGNITION"
                mode       = "DISALLOWED"
                notes      = "No direct modulation of meta-cognition; support must be via indirect, host-visible methods."
            }
        ]
    }

    excluded_domains {
        # Aligns with your red-lines shard to prevent catastrophic misuse.[web:96][web:116][web:133][web:134][web:136][web:138]
        references = [
            "/aln-bci-special/bci.special.red-lines.prohibited-uses.aln::CORE_BELIEF_KERNEL_MODULATION",
            "/aln-bci-special/bci.special.red-lines.prohibited-uses.aln::LONG_TERM_AFFECTIVE_CONDITIONING",
            "/aln-bci-special/bci.special.red-lines.prohibited-uses.aln::NEURAL_BEHAVIORAL_SCORING_LOOPS",
            "/aln-bci-special/bci.special.red-lines.prohibited-uses.aln::META_COGNITIVE_EXPLOITATION"
        ]

        rule = "NO_CONSENT_ENVELOPE_OR_CLINICAL_PLAN_MAY_CONFLICT_WITH_THESE_RED_LINES"
    }

    ###########################################################################
    # 5. Session limits, monitoring, and review
    ###########################################################################

    session_limits {
        max_sessions_per_week   = 5
        max_sessions_total      = 60
        max_duration_minutes    = 60

        rules = [
            "SESSION_COUNT_AND_DURATION_MUST_BE_TRACKED",
            "EXTENSIONS_REQUIRE_SEPARATE_REVIEW_AND_UPDATED_CONSENT"
        ][web:142][web:144]
    }

    monitoring_and_safety {
        requirements = [
            "MONITOR_FOR_ACUTE_DISTRESS_OR_UNEXPECTED_EFFECTS_DURING_AND_AFTER_SESSIONS",
            "DOCUMENT_ANY_ADVERSE_EVENTS_AND_NOTIFY_HOST",
            "INCLUDE_EMERGENCY_STOP_CONDITION_IF_RISK_THRESHOLD_EXCEEDED"
        ][web:142][web:144]

        continuity_protection = [
            "EVALUATE_FOR_CHANGES_IN_SELF_REPORT_OF_IDENTITY_OR_CONTINUITY",
            "IF_MATERIAL_IDENTITY_SHIFT_DETECTED: PAUSE_MODALITY_AND_REVIEW"
        ]
    }

    review_schedule {
        min_review_interval_days = 30
        review_required_events   = [
            "SIGNIFICANT_SYMPTOM_CHANGE",
            "ADVERSE_EVENT",
            "HOST_REQUEST_FOR_REVIEW"
        ]

        outputs = [
            "UPDATED_RISK_BENEFIT_SUMMARY",
            "RECOMMENDED_CONTINUATION_OR_ADJUSTMENT",
            "LOGGED_DECISION_WITH_HOST_ACKNOWLEDGMENT"
        ]
    }

    ###########################################################################
    # 6. Informed consent, disclosure, and host control
    ###########################################################################

    informed_consent {
        disclosure_requirements = [
            "EXPLAIN_CLINICAL_INDICATION_AND_ALTERNATIVES",
            "EXPLAIN_KNOWN_RISKS_AND_UNKNOWNS_IN_PLAIN_LANGUAGE",
            "EXPLAIN_THAT_REFUSAL_OR_REVOCATION_WILL_NOT_LEAD_TO_PUNITIVE_ACTION",
            "EXPLAIN_WHAT_DATA_IS_RECORDED_AND_FOR_HOW_LONG"
        ][web:96][web:118][web:140][web:142][web:144]

        host_control = [
            "HOST_MUST_HAVE_CLEAR_PATH_TO_PAUSE_OR_STOP_A_SESSION",
            "HOST_CAN_REQUEST_PARAMETER_ADJUSTMENTS_WITHIN_SAFETY_LIMITS",
            "HOST_CAN_REQUEST_SECOND_OPINION_OR_EXTERNAL_REVIEW"
        ]
    }

    ###########################################################################
    # 7. Validity window, renewal, and revocation
    ###########################################################################

    validity {
        max_duration_days = 180
        renewal_mode      = "EXPLICIT_RENEWAL_WITH_FRESH_DISCLOSURE"

        rules = [
            "AFTER_VALIDITY_EXPIRY_NO_FURTHER_MODULATION_CAN_OCCUR",
            "RENEWAL_REQUIRES_UPDATED_RISK_BENEFIT_SUMMARY"
        ]
    }

    revocation_procedure {
        mechanism = [
            "HOST_CAN_REVOKE_CONSENT_BETWEEN_SESSIONS_WITH_MINIMAL_FRICTION",
            "IN_EMERGENCY_HOST_CAN_REQUEST_STOP_DURING_SESSION"
        ]

        effects = [
            "STOP_ALL_FUTURE_MODULATION_SESSIONS",
            "REVIEW_WHETHER_ANY_RESIDUAL_EFFECTS_REQUIRE_REMEDIAL_ACTION",
            "LOG_REVOCATION_EVENT_AND_REASON_WHEN_PROVIDED"
        ][web:96][web:77][web:140][web:142]
    }

    ###########################################################################
    # 8. Audit integration
    ###########################################################################

    audit_linkage {
        events_emitted = [
            "CONSENT_THERAPEUTIC_MODULATION_GRANTED",
            "CONSENT_THERAPEUTIC_MODULATION_RENEWED",
            "CONSENT_THERAPEUTIC_MODULATION_REVOKED",
            "THERAPEUTIC_MODULATION_SESSION_STARTED",
            "THERAPEUTIC_MODULATION_SESSION_ENDED",
            "THERAPEUTIC_MODULATION_ADVERSE_EVENT"
        ]

        audit_schema_refs = [
            "/aln-audit-ledger/audit.schema.events.aln",
            "/aln-audit-ledger/audit.index.schema.aln"
        ]

        required_fields_per_event = [
            "EVENT_ID",
            "TIMESTAMP",
            "HOST_DID",
            "BOSTROM_ADDRESS",
            "ENVELOPE_ID",
            "CLINICAL_INDICATION",
            "CHANNELS_USED",
            "SESSION_PARAMETERS",
            "RESPONSIBLE_CLINICIAN_ID"
        ]
    }
}
