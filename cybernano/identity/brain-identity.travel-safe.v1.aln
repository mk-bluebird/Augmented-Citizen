aln
destination-path cybernano/identity/brain-identity.travel-safe.v1.aln

particle brain.identity.travel-safe.v1

meta
  id brain.identity.travel-safe.v1
  version 1.0.0
  hostdid didalnorganic-host
  bostromaddress bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
  domain transit-identity
  migrationClause ALN.MIGRATION.CYBERCOREAUTHORITY.v1
  noRollback true
  monotoneTighteningOnly true
endmeta

record TravelSafeCredential
  reference_id string
  hostdid string
  bostromaddress string
  brain_identity_envelope_id string
  citypass_issuer_id string
  valid_from_utc string
  valid_until_utc string
  roh_ceiling float
  psychrisk_ceiling float
  neurorights_floor_bits string
  eco_reward_eligible bool
  learning_only bool
  signature_alg string
  signature_hex string
end

constraints TravelSafeCredential
  require hostdid didalnorganic-host
  require bostromaddress bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
  require roh_ceiling 0.30
  require psychrisk_ceiling 0.0
  require psychrisk_ceiling 1.0
  if learning_only true
    require eco_reward_eligible false
  endif
endconstraints
