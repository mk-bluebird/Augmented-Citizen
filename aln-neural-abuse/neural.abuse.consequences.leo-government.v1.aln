# File: aln-neural-abuse/neural.abuse.consequences.leo-government.v1.aln
# Destination: aln-neural-abuse/neural.abuse.consequences.leo-government.v1.aln

aln neural.abuse.consequences.leo-government.v1

meta
  id neural.abuse.consequences.leo-government.v1
  version 1.0.0
  description Unified consequence particle encoding 100 enforceable responses to LEO/Government neural abuse and psych-harm.
  authoritybinding ALN.MIGRATION.CYBERCORE_AUTHORITY.v1
  hostdid_field hostdid
  bostromaddress_field bostrom_address
endmeta

struct Consequence
  id                u16    # 1..100, stable identifier.
  name              string # Short label.
  domain            string # BCI_PSYCH, NANOSWARM, DATACENTER_AI, LEGAL_EVIDENCE, PUBLIC_NARRATIVE, ECONOMIC_EVOLUTION.
  effect            string # One-sentence description of what happens.
  guard_locus       string # Guard or subsystem expected to implement this (conceptual path).
  aln_binding       string # Shard and field path this consequence binds to.
  severity          string # LOW, MEDIUM, HIGH, EXTREME.
  actor_scope       string # LEO, DEFENSE, INTEL, STATE_ACTOR, ANY.
endstruct

struct LeoGovernmentAbuseConsequences
  hostdid          string
  bostrom_address  string
  psych_debt_bonus f32      # 2.0 encodes the 200% accountability multiplier for state-origin psych-harm.
  consequences     Consequence[]
endstruct

particle LeoGovernmentAbuseConsequences
  hostdid          "did:aln:bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7"
  bostrom_address  "bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7"
  psych_debt_bonus 2.0

  consequences [

