# filename: aln/augmented-id.age.policy.v1.aln

aln-shard augmented-id.age.policy.v1 {
    meta {
        host_did        = "did:aln:bostrom-organic-host";
        bostrom_address = "bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7";
        repo_authority  = "github.com/mk-bluebird/Augmented-Citizen";
        clause_aln_migration = "ALN.MIGRATION.CYBERCORE_AUTHORITY.v1";
        description = "Augmented-ID age policy shard defining age-band predicates, issuer trust lists, and selective disclosure rules.";
        version = 1;
    }

    age_bands {
        # Age bands are inclusive lower bounds.
        band_over_13  = 13;
        band_over_16  = 16;
        band_over_18  = 18;
        band_over_21  = 21;
        band_over_25  = 25;
    }

    issuer_trust_list {
        # Trusted issuer DIDs for age credentials.
        issuers = [
            "did:aln:issuer.gov.az",
            "did:aln:issuer.bank.global",
            "did:aln:issuer.health.system",
            "did:aln:issuer.community.id"
        ];

        # Issuers must satisfy these constraints to remain trusted.
        constraints {
            require_revocation_registry = true;
            require_audit_log_binding   = true;
            require_neurorights_clause  = "ALN.NEURORIGHTS.NONONCONSENSUALMODULATION";
        }
    }

    selective_disclosure_rules {
        # Minimal attribute set exposed for age verification.
        exported_fields = [
            "age_band",          # e.g., "over_18"
            "credential_id",     # stable identifier for VC
            "issuer_did",        # DID of issuer
            "subject_did",       # DID of host
            "expiry_timestamp",  # credential expiry
            "revocation_state"   # active / revoked
        ];

        # Forbidden fields MUST NOT appear in exported payloads.
        telemetry_forbidden = [
            "full_name",
            "date_of_birth",
            "address",
            "photo_id_image",
            "raw_eeg",
            "raw_bci",
            "raw_biometric_template",
            "full_medical_record"
        ];

        # Policy for encoding age band.
        age_encoding {
            # Age band is a categorical label; no exact birthdate is exported.
            format = "label";  # allowed: "label", "range"
            labels = [
                "over_13",
                "over_16",
                "over_18",
                "over_21",
                "over_25"
            ];
        }
    }

    predicate AugmentedIdAgeBandOK {
        inputs {
            requested_band : string;  # e.g., "over_18"
            credential_band: string;  # declared band in VC
        }

        definition {
            # The credential band must be equal or stricter than the requested band.
            # Strictness order is: over_25 > over_21 > over_18 > over_16 > over_13.
            let order = {
                "over_13" : 1,
                "over_16" : 2,
                "over_18" : 3,
                "over_21" : 4,
                "over_25" : 5
            };

            let requested_level  = order[requested_band];
            let credential_level = order[credential_band];

            return credential_level >= requested_level;
        }
    }

    predicate AugmentedIdIssuerTrusted {
        inputs {
            issuer_did : string;
        }

        definition {
            return issuer_did in issuer_trust_list.issuers;
        }
    }

    predicate AugmentedIdCredentialFresh {
        inputs {
            now_timestamp    : u64;
            expiry_timestamp : u64;
            revocation_state : string;  # "active" | "revoked"
        }

        definition {
            let not_expired = now_timestamp <= expiry_timestamp;
            let not_revoked = revocation_state == "active";

            return not_expired && not_revoked;
        }
    }

    predicate AugmentedIdSelectiveDisclosureOK {
        inputs {
            exported_fields : [string];
            forbidden       : [string];
        }

        definition {
            # Ensure no forbidden field is present in exported_fields.
            for field in exported_fields {
                if field in forbidden {
                    return false;
                }
            }

            return true;
        }
    }

    predicate AugmentedIdAgePolicySatisfied {
        inputs {
            requested_band   : string;
            credential_band  : string;
            issuer_did       : string;
            now_timestamp    : u64;
            expiry_timestamp : u64;
            revocation_state : string;
            exported_fields  : [string];
        }

        definition {
            let band_ok   = AugmentedIdAgeBandOK { requested_band, credential_band };
            let issuer_ok = AugmentedIdIssuerTrusted { issuer_did };
            let fresh_ok  = AugmentedIdCredentialFresh { now_timestamp, expiry_timestamp, revocation_state };
            let sd_ok     = AugmentedIdSelectiveDisclosureOK {
                exported_fields,
                selective_disclosure_rules.telemetry_forbidden
            };

            return band_ok && issuer_ok && fresh_ok && sd_ok;
        }
    }
}
