# Which token set and .evo consent schema govern neural intent
intent.token_set_id,host_intent_tokens_v1
intent.token_set_shard,neural.intent_token_set.v1

intent.evo_policy_id,neural-intent-consent.v1
intent.evo_policy_mode_required,Conservative
intent.evo_policy_shard,neuro.consent.neural-intent.v1

# Hard invariants for any neural intent path
intent.domain.scope,OUTERONLY
intent.forbid.raw_neural_inputs,true

intent.neurorights.flags_required,cognitive_liberty
intent.neurorights.flags_required,mental_privacy
intent.neurorights.flags_required,augmentation_continuity
intent.neurorights.flags_required,project_continuity

# Psych / slavery / RoH ceilings for any intent-sourced request
intent.psychriskindex.max,0.65
intent.slaveryriskindex.max,0.40
intent.roh.ceiling,0.30

# Enforcement: no weaker policy allowed
governance.noRollback,true
governance.noDowngrade,true
governance.noMicroReversal,true
governance.mustImport,psych.slavery.guard.v1
governance.mustImport,cybercore-sovereign-host-kernel-v1
