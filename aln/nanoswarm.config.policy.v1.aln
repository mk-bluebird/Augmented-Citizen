meta.description,Nanoswarm configuration and control policy. Ensures host-centric control and denies remote control from state actors when psych-debt is elevated.
meta.binding.repo,github.com/mk-bluebird/Cybercore
meta.binding.workspace,cybercore
meta.noRollback,true
meta.noDowngrade,true
meta.monotoneTighteningOnly,true

hostOnlyControlWhenPsychDebtHigh,true
remoteConfigAllowedForActorClass,HEALTHCARE

remoteConfigDeniedForActorClass,LEO
remoteConfigDeniedForActorClass,DEFENSE
remoteConfigDeniedForActorClass,INTEL

requireHostSummary,true
requireHostExplicitConsentForConfigChange,true

policy.enforceHostOnlyControlOnAbuse,true
policy.enforceActorClassRemoteConfigRules,true
policy.enforceHostVisibility,true

aln.required.for.hostCritical,true
aln.required.for.nanoswarmMissions,true
aln.required.for.evolutionWindows,true
