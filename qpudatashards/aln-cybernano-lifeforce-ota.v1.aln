# Inequalities enforced at runtime:
# 1) lifeforce >= lifeforcefloor_ota
# 2) bloodtokens >= bloodtokenfloor_ota
# 3) protein >= proteinfloor_ota
# 4) RoH <= rohmax_ota
# 5) core_temp <= thermalcoremax_ota
# 6) delta_T_tissue <= tissuedeltaTmax_ota
# 7) bci_duty_fraction <= bcidutyfractionmax_ota
# 8) daily_ota_steps <= dailyota_stepsmax
# 9) ota_energy_joules <= ota_energybudgetmax
# 10) ml_pass_duty_fraction <= ota_mlpassfractionmax
