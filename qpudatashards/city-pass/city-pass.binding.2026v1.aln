aln
aln destination-path qpudatashards/city-pass/city-pass.binding.2026v1.aln

particle CityPassBindingShard2026v1
meta
  id                city-pass.binding.2026v1
  version           1.0.0
  description       "Host-bound, forward-only binding for offline city transit passes with eco savings and neurorights/eco-contract guards."
  hostdid           didalnorganic-host
  bostromaddress    bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
  authority         ALN.MIGRATION.CYBERCORE_AUTHORITY.v1
  noRollback        true
  noDowngrade       true
  monotoneTighteningOnly true
endmeta

record CityPassBindingRecord2026v1
  string  binding_id             // host-local BindingId string
  string  host_did
  string  host_bostrom
  string  city_id
  string  pass_cap_id
  string  validity_start_utc
  string  validity_end_utc
  uint32  max_taps
  uint32  taps_used
  float   eco_kwh_baseline_per_trip
  float   eco_kwh_transit_per_trip
  float   eco_savings_kwh
  string  neurorights_contract_id
  string  ecocontract_id
  string  hex_commit
endrecord

constraints CityPassBindingRecord2026v1
  require host_did        != ""
  require host_bostrom    != ""
  require validity_start_utc != ""
  require validity_end_utc   != ""
  require max_taps        > 0
  require taps_used       <= max_taps
  require eco_kwh_baseline_per_trip >= 0.0
  require eco_kwh_transit_per_trip  >= 0.0
  require eco_kwh_baseline_per_trip >= eco_kwh_transit_per_trip
  require eco_savings_kwh  >= 0.0
endconstraints

events CityPassBindingRecord2026v1
  type        CITY_PASS_BINDING
  route       data-lake.city-pass
  severityfield eco_savings_kwh
  hostfield   host_did
  devicefield binding_id
  anchor      organichain.risk.anchor.v1 optional
endevents
endaln
